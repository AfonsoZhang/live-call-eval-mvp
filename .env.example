# Anthropic (recommended for --sut anthropic)
ANTHROPIC_API_KEY=your_anthropic_key
SUT_MODEL=claude-sonnet-4-20250514
SUT_API_BASE_URL=https://api.anthropic.com
SUT_ANTHROPIC_VERSION=2023-06-01
SUT_MAX_TOKENS=1024
SUT_TIMEOUT=60

# OpenAI-compatible (for --sut openai)
# SUT_API_KEY=your_api_key
# SUT_MODEL=your_model
# SUT_API_BASE_URL=https://api.openai.com/v1
