# 复制为 .env 并填入真实密钥（.env 不会提交到 Git）
# copy .env.example .env

# ===== SUT (被测客服) =====
SUT_API_KEY=your_api_key_here
SUT_MODEL=your_model_name
SUT_API_BASE_URL=https://api.anthropic.com
SUT_ANTHROPIC_VERSION=2023-06-01
SUT_MAX_TOKENS=1024
SUT_TIMEOUT=60

# ===== User Simulator LLM (--simulator llm|hybrid) =====
SIMULATOR_API_KEY=your_api_key_here
SIMULATOR_MODEL=your_model_name
SIMULATOR_PROTOCOL=anthropic
SIMULATOR_API_BASE_URL=https://api.anthropic.com
SIMULATOR_ANTHROPIC_VERSION=2023-06-01
SIMULATOR_MAX_TOKENS=1024
SIMULATOR_TIMEOUT=60

# ===== LLM Judge (--judge llm) =====
JUDGE_API_KEY=your_api_key_here
JUDGE_MODEL=your_model_name
JUDGE_PROTOCOL=anthropic
JUDGE_API_BASE_URL=https://api.anthropic.com
JUDGE_ANTHROPIC_VERSION=2023-06-01
JUDGE_MAX_TOKENS=1024
JUDGE_TIMEOUT=60

# OpenAI-compatible example:
# SUT_PROTOCOL=openai
# SIMULATOR_PROTOCOL=openai
# SIMULATOR_API_BASE_URL=https://api.openai.com/v1
# JUDGE_PROTOCOL=openai
# JUDGE_API_BASE_URL=https://api.openai.com/v1
